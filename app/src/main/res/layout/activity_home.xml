<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4FC3F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvHello"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello, Student"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <TextView
            android:id="@+id/tvTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Personalised Learning Task"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#000000"
            android:layout_marginTop="30dp" />

        <TextView
            android:id="@+id/tvTaskDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Short description for the generated task"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnGenerateFlashcards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generate 3 AI Flashcards"
            android:layout_marginTop="20dp"
            android:backgroundTint="#FFC107" />

        <TextView
            android:id="@+id/tvPromptLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prompt:"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/tvPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="15sp"
            android:textColor="#000000"
            android:background="#B3E5FC"
            android:padding="12dp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tvFlashcardsLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI Response:"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvFlashcards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="15sp"
            android:textColor="#000000"
            android:background="#E1F5FE"
            android:padding="12dp"
            android:layout_marginTop="6dp" />

        <Button
            android:id="@+id/btnOpenTask"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open Task"
            android:layout_marginTop="24dp"
            android:backgroundTint="#00E676" />
    </LinearLayout>
</ScrollView>